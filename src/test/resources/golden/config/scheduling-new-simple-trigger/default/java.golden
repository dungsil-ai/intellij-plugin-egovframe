package egovframework.example.config;

import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.scheduling.quartz.JobDetailFactoryBean;
import org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean;
import org.springframework.scheduling.quartz.SimpleTriggerFactoryBean;

/**
 * Simple Trigger Configuration for Quartz Scheduler
 * Spring Framework 6.x compatible
 * 
 * Requirements:
 * - Spring Framework 6.x
 * - Quartz Scheduler 2.3.2+
 * - JDK 17+
 */
@Configuration
public class EgovSchedulingSimpleTriggerConfig {

    /**
     * SimpleTrigger 설정
     * 일정한 간격으로 Job을 실행
     */
    @Bean(name = "simpleTrigger")
    public SimpleTriggerFactoryBean simpleTrigger(@Qualifier("jobDetail") JobDetailFactoryBean jobDetail) {
        SimpleTriggerFactoryBean trigger = new SimpleTriggerFactoryBean();
        trigger.setJobDetail(jobDetail.getObject());
        trigger.setStartDelay(2000); // 2000ms 후에 시작
        trigger.setRepeatInterval(10000); // 매 10000ms마다 실행
        return trigger;
    }
}
