package egovframework.example.config;

import com.mchange.v2.c3p0.ComboPooledDataSource;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import javax.sql.DataSource;
import java.beans.PropertyVetoException;

/**
 * C3P0 DataSource Configuration
 * Spring Framework 6.x, Jakarta EE 9 호환
 */
@Configuration
public class context-datasource {

  @Bean(name = "dataSource", destroyMethod = "close")
  public DataSource dataSource(
      @Value("com.mysql.cj.jdbc.Driver") String driverClassName,
      @Value("jdbc:mysql://127.0.0.1:3306/myDB") String url,
      @Value("root") String username,
      @Value("") String password) throws PropertyVetoException {

    ComboPooledDataSource dataSource = new ComboPooledDataSource();
    dataSource.setDriverClass(driverClassName);
    dataSource.setJdbcUrl(url);
    dataSource.setUser(username);

    if (password != null && !password.isEmpty()) {
      dataSource.setPassword(password);
    }

    dataSource.setInitialPoolSize(3);
    dataSource.setMinPoolSize(3);
    dataSource.setMaxPoolSize(50);
    dataSource.setIdleConnectionTestPeriod(200);
    dataSource.setAcquireIncrement(1);
    dataSource.setMaxStatements(0);
    dataSource.setNumHelperThreads(3);

    return dataSource;
  }

  /*
   * 다음 라이브러리 추가 필요
   * Spring Framework 6.x, Jakarta EE 9 호환
   * 
   * === Maven pom.xml ===
   * <dependency>
   *   <groupId>com.mchange</groupId>
   *   <artifactId>c3p0</artifactId>
   *   <version>0.10.1</version>
   * </dependency>
   * 
   * === Gradle ===
   * implementation 'com.mchange:c3p0:0.10.1'
   */
}
