package egovframework.example.config;

import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean;

import egovframework.example.schedule.JobService;

/**
 * Method Invoking Job Detail Configuration for Quartz Scheduler
 * Spring Framework 6.x compatible
 * 
 * Requirements:
 * - Spring Framework 6.x
 * - Quartz Scheduler 2.3.2+
 * - JDK 17+
 */
@Configuration
public class EgovSchedulingMethodInvokingJobDetailConfig {

    /**
     * MethodInvoking JobDetail 설정
     * @Service 등으로 등록된 Bean의 특정 메소드를 주기적으로 실행
     */
    @Bean(name = "methodInvokingJobDetail")
    public MethodInvokingJobDetailFactoryBean methodInvokingJobDetail(egovframework.example.schedule.JobService jobService) {
        MethodInvokingJobDetailFactoryBean jobDetailFactory = new MethodInvokingJobDetailFactoryBean();
        jobDetailFactory.setTargetObject(jobService);
        jobDetailFactory.setTargetMethod("executeSample");
        jobDetailFactory.setConcurrent(false);
        return jobDetailFactory;
    }

    // 스케줄로 실행될 실제 서비스 로직인 egovframework.example.schedule.JobService 클래스를 생성한 후
    // 그 클래스 내에서 "@Service" 등의 어노테이션을 사용하여 "jobService" Bean을 등록한다.
}
