<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean name="idGnrService" class="org.egovframe.rte.fdl.idgnr.impl.EgovTableIdGnrServiceImpl" destroy-method="destroy">
        <property name="dataSource" ref="dataSource"/>
        <property name="table"	  value="IDS"/>
        <property name="tableName"  value="SAMPLE"/>	
        <property name="blockSize" value="10"/>
        <property name="strategy" ref="prefixIdGnrStrategy"/>
    </bean>	

    <bean name="prefixIdGnrStrategy" class="org.egovframe.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
        <property name="prefix" value="egov-"/>
        <property name="cipers" value="10"/>
        <property name="fillChar" value="0"/>
    </bean>
</beans>
