<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean name="propertiesService" class="org.egovframe.rte.fdl.property.impl.EgovPropertyServiceImpl" destroy-method="destroy">

        
        <property name="extFileName">
            <set>
                <!-- MAP을 이용해서 encoding 정보를 입력하는 방법 -->
                <map>
                    <entry key="encoding" value="UTF-8"/>
                    <entry key="filename" value="classpath*:/egovframework/egovProps/conf/config.properties"/>
                </map>
                <!-- 단일 값 입력 방법 : 필요시 아래와 같은 방식으로 단일 값 추가 -->
                <!-- <value>classpath*:/egovframework/egovProps/conf/config.properties</value> -->
            </set>
        </property>	
      
    </bean>    
    
</beans>
