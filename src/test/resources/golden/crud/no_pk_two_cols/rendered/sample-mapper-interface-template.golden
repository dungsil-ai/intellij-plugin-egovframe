@EgovMapper("tmpLogMapper")
public interface TmpLogMapper {

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 TmpLogVO
	 * @return 등록 결과
	 * @exception Exception
	 */
	void insertTmpLog(TmpLogVO vo) throws Exception;

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 TmpLogVO
	 * @return void형
	 * @exception Exception
	 */
	void updateTmpLog(TmpLogVO vo) throws Exception;

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 TmpLogVO
	 * @return void형
	 * @exception Exception
	 */
	void deleteTmpLog(TmpLogVO vo) throws Exception;

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 TmpLogVO
	 * @return 조회한 글
	 * @exception Exception
	 */
	TmpLogVO selectTmpLog(TmpLogVO vo) throws Exception;

	/**
	 * 글 목록을 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 목록
	 * @exception Exception
	 */
	List<?> selectTmpLogList(TmpLogVO vo) throws Exception;

	/**
	 * 글 총 갯수를 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 총 갯수
	 * @exception
	 */
	int selectTmpLogListTotCnt(TmpLogVO vo);

}
