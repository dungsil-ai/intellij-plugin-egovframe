<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<title>List</title>

	<!-- KRDS CSS -->
	<link rel="stylesheet" type="text/css" th:href="@{/css/component/output.css}"/>
	<link rel="stylesheet" type="text/css" th:href="@{/css/egovframe.css}"/>
	<script th:inline="javascript" th:src="@{/js/jquery.min.js}"></script>
	<script th:inline="javascript" th:src="@{/js/egovframework/common.js}" defer></script>
	<script th:inline="javascript" defer>
		const contextPath = $('#contextPathHolder').attr('data-contextPath') ? $('#contextPathHolder').attr('data-contextPath') : '';

		function notNullCheck(value) {
		    return !(value === '' || value == null || (typeof value == 'object' && !Object.keys(value).length));
		}

		function fn_egov_selectList() {
            if (notNullCheck($('#searchKeyword').val())) {
				$('#listForm').attr('method', 'get').attr('action', contextPath + '/tmpLog/tmpLogList.do').submit();
            } else {
            	alert('Please enter search keyword');
            }
		}

		function fn_egov_link_page(pageIndex) {
        	$('#pageIndex').val(pageIndex);
        	$('#listForm').attr('method', 'get').attr('action', contextPath + '/tmpLog/tmpLogList.do').submit();
        }

        function fn_egov_addView() {
        	$('#listForm').attr('method', `post`).attr('action', contextPath + '/tmpLog/addTmpLogView.do').submit();
        }

        function fn_egov_select(logMessage) {
			$('#logMessage').val(logMessage);
            $('#listForm').attr('method', 'post').attr('action', contextPath + '/tmpLog/updateTmpLogView.do').submit();
        }
    </script>
</head>

<body>
<div id="container" class="inner">

	<!-- Page Title -->
	<h2 class="heading-large">List</h2>

	<div id="content_pop">
		<form id="listForm" th:object="${tmpLogVO}">
			<input type="hidden" th:id="logMessage" th:name="logMessage" />
			<input type="hidden" th:id="pageIndex" th:name="pageIndex" th:value="1" />

			<!-- Search Form -->
			<div class="form-group">
				<div class="search-wrap">
					<div class="search-body">
						<div class="form-conts searchOption">
							<select id="searchCondition" name="searchCondition" class="krds-form-select medium" title="Choose search condition">
								<option value="1" th:selected="${tmpLogVO.searchCondition} &#x3D;&#x3D; 1">LoggedAt</option>
								<option value="0" th:selected="${tmpLogVO.searchCondition} &#x3D;&#x3D; 0">LogMessage</option>
							</select>
						</div>
						<div class="form-conts btn-ico-wrap searchKeyword">
							<input type="text" id="searchKeyword" name="searchKeyword" th:value="${tmpLogVO.searchKeyword}" class="krds-input medium" placeholder="Search keyword">
							<button type="button" class="krds-btn medium icon" th:onclick="fn_egov_selectList()">
								<span class="sr-only">Search</span>
								<i class="svg-icon ico-sch"></i>
							</button>
						</div>
					</div>
					<div class="page-btn-wrap">
						<button type="button" class="krds-btn medium" th:onclick="fn_egov_addView()">Regist</button>
					</div>
				</div>
			</div>
		</form>

		<!-- List -->
		<div class="krds-table-wrap">
			<table class="tbl col data">
				<colgroup>
					<col style="width: 10%;">
					<col style="width: auto;">
					<col style="width: auto;">
				</colgroup>

				<thead>
					<tr>
						<th scope="col" class="text-center">No</th>
						<th scope="col" class="text-center">LogMessage</th>
						<th scope="col" class="text-center">LoggedAt</th>
					</tr>
				</thead>

				<tbody>
					<tr th:each="result, iterStat : ${resultList}">
					  <!-- 순번 계산 -->
						<td class="text-center" th:text="${paginationInfo.totalRecordCount + 1 - ((tmpLogVO.pageIndex - 1) * tmpLogVO.pageSize + iterStat.count)}"></td>
						<!-- PK 컬럼이 없다면, 첫 번째 컬럼이 PK 역할 수행하여 SQL문의 WHERE 조건에 사용됨 -->
						<td class="text-center">
							<a href="#" th:onclick="fn_egov_select([[${result.logMessage}]])" th:text="${result.logMessage}"></a>
						</td>
						<!-- 일반 컬럼: 단순 출력 -->
						<td class="text-center" th:text="${result.loggedAt}"></td>
					</tr>
					<tr th:if="${resultList == null or resultList.isEmpty()}">
						<td class="text-center" colspan="3">No data found</td>
					</tr>
				</tbody>
			</table>
		</div>

		<!-- Pagination -->
		<div id="paging" class="krds-pagination w-page" th:utext="${#egovKrdsPaginationRenderer.renderPagination(paginationInfo, 'fn_egov_link_page')}"></div>

	</div>

</div>

</body>
</html>
