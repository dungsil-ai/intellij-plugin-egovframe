package egovframework.example.sample.service.impl;

import java.util.List;

import org.egovframe.rte.fdl.cmmn.EgovAbstractServiceImpl;
import org.egovframe.rte.fdl.idgnr.EgovIdGnrService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;

import egovframework.example.sample.service.TmpLogService;
import egovframework.example.sample.service.TmpLogVO;
import jakarta.annotation.Resource;

/**
 * @Class Name : TmpLogServiceImpl.java
 * @Description : TmpLog Business Implement Class
 * @Modification Information
 * @
 * @ 수정일 수정자 수정내용
 * @ --------- --------- -------------------------------
 * @ 2026-07-16 author 최초생성
 *
 * @author author
 * @since 2026-07-16
 * @version 1.0.0
 * @see
 *
 * Copyright (C) All right reserved.
 */
@Service("tmpLogService")
public class TmpLogServiceImpl extends EgovAbstractServiceImpl implements TmpLogService {

	private static final Logger LOGGER = LoggerFactory.getLogger(TmpLogServiceImpl.class);

	/** TmpLogMapper */
	@Resource(name = "tmpLogMapper")
	private TmpLogMapper tmpLogMapper;

	/** ID Generation */
	@Resource(name = "egovIdGnrService")
	private EgovIdGnrService egovIdGnrService;

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 TmpLogVO
	 * @exception Exception
	 */
	@Override
	public void insertTmpLog(TmpLogVO vo) throws Exception {
		LOGGER.debug(vo.toString());

		/** ID Generation Service */
		String id = egovIdGnrService.getNextStringId();
		vo.setLogMessage(id);
		LOGGER.debug(vo.toString());

		tmpLogMapper.insertTmpLog(vo);
	}

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 TmpLogVO
	 * @exception Exception
	 */
	@Override
	public void updateTmpLog(TmpLogVO vo) throws Exception {
		tmpLogMapper.updateTmpLog(vo);
	}

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 TmpLogVO
	 * @exception Exception
	 */
	@Override
	public void deleteTmpLog(TmpLogVO vo) throws Exception {
		tmpLogMapper.deleteTmpLog(vo);
	}

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 TmpLogVO
	 * @return 조회한 글
	 * @exception Exception
	 */
	@Override
	public TmpLogVO selectTmpLog(TmpLogVO vo) throws Exception {
		TmpLogVO resultVO = tmpLogMapper.selectTmpLog(vo);
		// if (resultVO == null)
		//  	throw processException("info.nodata.msg");
		return resultVO;
	}

	/**
	 * 글 목록을 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 목록
	 * @exception Exception
	 */
	@Override
	public List<?> selectTmpLogList(TmpLogVO vo) throws Exception {
		return tmpLogMapper.selectTmpLogList(vo);
	}

	/**
	 * 글 총 갯수를 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 총 갯수
	 * @exception
	 */
	@Override
	public int selectTmpLogListTotCnt(TmpLogVO vo) {
		return tmpLogMapper.selectTmpLogListTotCnt(vo);
	}

}
