<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org" th:with="registerFlag=${#strings.isEmpty(eventInfoVO.eventId)} ? 'create' : 'modify'">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title th:if="registerFlag == 'modify'">EventInfo Update</title>
    <title th:if="registerFlag == 'create'">EventInfo Regist</title>

    <!-- KRDS CSS -->
	<link rel="stylesheet" type="text/css" th:href="@{/css/component/output.css}">
	<link rel="stylesheet" type="text/css" th:href="@{/css/egovframe.css}">
	<script th:inline="javascript" th:src="@{/js/jquery.min.js}"></script>
	<script th:inline="javascript" th:src="@{/js/component/ui-script.js}" defer></script>
	<script th:inline="javascript" th:src="@{/js/egovframework/common.js}" defer></script>

	<!--For Custom Validation-->
	<!-- egovframe-Todo: Validator 적용시 아래 주석 코드 참고 -->
    <!-- <script th:inline="javascript" th:src="@{/js/egovframework/EgovValidation.js}" defer></script> -->

    <script th:inline="javascript" defer>
	    function fn_egov_list() {
            $('#detailForm').attr('method', 'get').attr('action', contextPath + '/eventInfo/eventInfoList.do').submit();
        }

        function fn_egov_add() {
            if (confirm('Are you sure you want to register?')) {
                let frm = document.detailForm;
                // egovframe-Todo: Validator 적용시 아래 주석 코드 참고
                // EgovValidation.js 파일에 validateEventInfoVO 함수 추가 필요
                // if (!validateEventInfoVO(frm)) {
				//	  return;
				// }
				$('#detailForm').attr('method', 'post').attr('action', contextPath + '/eventInfo/addEventInfo.do').submit();
            }
        }

        function fn_egov_update() {
            if (confirm('Are you sure you want to modify?')) {
            	let frm = document.detailForm;
                // egovframe-Todo: Validator 적용시 아래 주석 코드 참고
                // EgovValidation.js 파일에 validateEventInfoVO 함수 추가 필요
                // if (!validateEventInfoVO(frm)) {
				//	  return;
				// }
            	$('#detailForm').attr('method', 'post').attr('action', contextPath + '/eventInfo/updateEventInfo.do').submit();
			}
        }

        function fn_egov_delete() {
            if (confirm('Are you sure you want to delete?')) {
                $('#detailForm').attr('method', 'post').attr('action', contextPath + '/eventInfo/deleteEventInfo.do').submit();
            }
        }

        function fn_egov_reset() {
            $('form').each(function() {
                this.reset();
            });
        }
    </script>
</head>

<body>
<div id="container" class="inner">

	<!-- Page Title -->
	<h2 class="heading-large">
	    <span th:if="${registerFlag == 'modify'}">Update</span>
	    <span th:if="${registerFlag == 'create'}">Regist</span>
	</h2>

	<form id="detailForm" name="detailForm" th:object="${eventInfoVO}">
    <input type="hidden" th:id="searchCondition" th:name="searchCondition" th:value="${eventInfoVO.searchCondition}" />
    <input type="hidden" th:id="searchKeyword" th:name="searchKeyword" th:value="${eventInfoVO.searchKeyword}" />
    <input type="hidden" th:id="pageIndex" th:name="pageIndex" th:value="${eventInfoVO.pageIndex}" />

		<div class="conts-wrap">
	        <div class="fieldset input-form">
                <div class="form-group" th:if="${eventInfoVO.eventId !&#x3D; null}">
                <div class="form-group" th:if="${not #strings.isEmpty(eventInfoVO.eventId)}">
                    <div class="form-tit">
                        <label for="eventId">EventId</label>
                    </div>
                    <div class="form-conts">
                        <input type="text" id="eventId" name="eventId" class="krds-input" th:value="${eventInfoVO.eventId}" th:readonly="readonly">
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-tit">
                        <label for="eventName">EventName</label>
                    </div>
                    <div class="form-conts">
                        <input type="text" id="eventName" name="eventName" class="krds-input" th:value="${eventInfoVO.eventName}">
                        <span class="error-message" th:if="${#fields.hasErrors('eventName')}" th:errors="*eventName"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-tit">
                        <label for="description">Description</label>
                    </div>
                    <div class="form-conts">
                        <input type="text" id="description" name="description" class="krds-input" th:value="${eventInfoVO.description}">
                        <span class="error-message" th:if="${#fields.hasErrors('description')}" th:errors="*description"></span>
                    </div>
                </div>

            </div>

	        <!-- Action Buttons -->
	        <div class="page-btn-wrap">
                <div class="btn-wrap">
	                <button type="button" class="krds-btn medium secondary" th:onclick="fn_egov_list()">List</button>
	                <button type="button" class="krds-btn medium tertiary" th:onclick="fn_egov_reset()">Reset</button>
                </div>
	            <div class="btn-wrap">
					<button type="button"
	                        class="krds-btn medium"
	                        th:onclick="fn_egov_update()"
	                        th:if="${registerFlag == 'modify'}">Update</button>
	                <button type="button"
	                        class="krds-btn medium danger"
	                        th:onclick="fn_egov_delete()"
	                        th:if="${registerFlag == 'modify'}">Delete</button>
	                <button type="button"
	                        class="krds-btn medium"
	                        th:onclick="fn_egov_add()"
	                        th:if="${registerFlag == 'create'}">Regist</button>
	            </div>
	        </div>
		</div>

	</form>

</div>

</body>
</html>
