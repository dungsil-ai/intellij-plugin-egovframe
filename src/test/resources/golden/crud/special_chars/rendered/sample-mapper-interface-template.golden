@EgovMapper("eventInfoMapper")
public interface EventInfoMapper {

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 EventInfoVO
	 * @return 등록 결과
	 * @exception Exception
	 */
	void insertEventInfo(EventInfoVO vo) throws Exception;

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 EventInfoVO
	 * @return void형
	 * @exception Exception
	 */
	void updateEventInfo(EventInfoVO vo) throws Exception;

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 EventInfoVO
	 * @return void형
	 * @exception Exception
	 */
	void deleteEventInfo(EventInfoVO vo) throws Exception;

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 EventInfoVO
	 * @return 조회한 글
	 * @exception Exception
	 */
	EventInfoVO selectEventInfo(EventInfoVO vo) throws Exception;

	/**
	 * 글 목록을 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 목록
	 * @exception Exception
	 */
	List<?> selectEventInfoList(EventInfoVO vo) throws Exception;

	/**
	 * 글 총 갯수를 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 총 갯수
	 * @exception
	 */
	int selectEventInfoListTotCnt(EventInfoVO vo);

}
