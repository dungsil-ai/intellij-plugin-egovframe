package egovframework.example.sample.service.impl;

import java.util.List;

import org.egovframe.rte.psl.dataaccess.mapper.EgovMapper;

import egovframework.example.sample.service.EventInfoVO;

/**
* @Class Name : EventInfoMapper.java
* @Description : EventInfo에 관한 데이터처리 매퍼 클래스
* @Modification Information
* @
* @ 수정일 수정자 수정내용
* @ --------- --------- -------------------------------
* @ 2026-07-16 author 최초생성
*
* @author author
* @since 2026-07-16
