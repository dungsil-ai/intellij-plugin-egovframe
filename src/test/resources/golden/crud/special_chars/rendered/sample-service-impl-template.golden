package egovframework.example.sample.service.impl;

import java.util.List;

import org.egovframe.rte.fdl.cmmn.EgovAbstractServiceImpl;
import org.egovframe.rte.fdl.idgnr.EgovIdGnrService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;

import egovframework.example.sample.service.EventInfoService;
import egovframework.example.sample.service.EventInfoVO;
import jakarta.annotation.Resource;

/**
 * @Class Name : EventInfoServiceImpl.java
 * @Description : EventInfo Business Implement Class
 * @Modification Information
 * @
 * @ 수정일 수정자 수정내용
 * @ --------- --------- -------------------------------
 * @ 2026-07-16 author 최초생성
 *
 * @author author
 * @since 2026-07-16
 * @version 1.0.0
 * @see
 *
 * Copyright (C) All right reserved.
 */
@Service("eventInfoService")
public class EventInfoServiceImpl extends EgovAbstractServiceImpl implements EventInfoService {

	private static final Logger LOGGER = LoggerFactory.getLogger(EventInfoServiceImpl.class);

	/** EventInfoMapper */
	@Resource(name = "eventInfoMapper")
	private EventInfoMapper eventInfoMapper;

	/** ID Generation */
	@Resource(name = "egovIdGnrService")
	private EgovIdGnrService egovIdGnrService;

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 EventInfoVO
	 * @exception Exception
	 */
	@Override
	public void insertEventInfo(EventInfoVO vo) throws Exception {
		LOGGER.debug(vo.toString());

		/** ID Generation Service */
		String id = egovIdGnrService.getNextStringId();
		vo.setEventId(id);
		LOGGER.debug(vo.toString());

		eventInfoMapper.insertEventInfo(vo);
	}

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 EventInfoVO
	 * @exception Exception
	 */
	@Override
	public void updateEventInfo(EventInfoVO vo) throws Exception {
		eventInfoMapper.updateEventInfo(vo);
	}

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 EventInfoVO
	 * @exception Exception
	 */
	@Override
	public void deleteEventInfo(EventInfoVO vo) throws Exception {
		eventInfoMapper.deleteEventInfo(vo);
	}

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 EventInfoVO
	 * @return 조회한 글
	 * @exception Exception
	 */
	@Override
	public EventInfoVO selectEventInfo(EventInfoVO vo) throws Exception {
		EventInfoVO resultVO = eventInfoMapper.selectEventInfo(vo);
		// if (resultVO == null)
		//  	throw processException("info.nodata.msg");
		return resultVO;
	}

	/**
	 * 글 목록을 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 목록
	 * @exception Exception
	 */
	@Override
	public List<?> selectEventInfoList(EventInfoVO vo) throws Exception {
		return eventInfoMapper.selectEventInfoList(vo);
	}

	/**
	 * 글 총 갯수를 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 총 갯수
	 * @exception
	 */
	@Override
	public int selectEventInfoListTotCnt(EventInfoVO vo) {
		return eventInfoMapper.selectEventInfoListTotCnt(vo);
	}

}
