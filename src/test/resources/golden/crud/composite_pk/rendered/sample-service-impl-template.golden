package egovframework.example.sample.service.impl;

import java.util.List;

import org.egovframe.rte.fdl.cmmn.EgovAbstractServiceImpl;
import org.egovframe.rte.fdl.idgnr.EgovIdGnrService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;

import egovframework.example.sample.service.OrderItemService;
import egovframework.example.sample.service.OrderItemVO;
import jakarta.annotation.Resource;

/**
 * @Class Name : OrderItemServiceImpl.java
 * @Description : OrderItem Business Implement Class
 * @Modification Information
 * @
 * @ 수정일 수정자 수정내용
 * @ --------- --------- -------------------------------
 * @ 2026-07-16 author 최초생성
 *
 * @author author
 * @since 2026-07-16
 * @version 1.0.0
 * @see
 *
 * Copyright (C) All right reserved.
 */
@Service("orderItemService")
public class OrderItemServiceImpl extends EgovAbstractServiceImpl implements OrderItemService {

	private static final Logger LOGGER = LoggerFactory.getLogger(OrderItemServiceImpl.class);

	/** OrderItemMapper */
	@Resource(name = "orderItemMapper")
	private OrderItemMapper orderItemMapper;

	/** ID Generation */
	@Resource(name = "egovIdGnrService")
	private EgovIdGnrService egovIdGnrService;

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 OrderItemVO
	 * @exception Exception
	 */
	@Override
	public void insertOrderItem(OrderItemVO vo) throws Exception {
		LOGGER.debug(vo.toString());

		/** ID Generation Service */
		String id = egovIdGnrService.getNextStringId();
		// egovframe-Todo: PK가 복수일 경우 ID Generation 적용 방식 검토 필요
		vo.setOrderId(id);
		LOGGER.debug(vo.toString());

		orderItemMapper.insertOrderItem(vo);
	}

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 OrderItemVO
	 * @exception Exception
	 */
	@Override
	public void updateOrderItem(OrderItemVO vo) throws Exception {
		orderItemMapper.updateOrderItem(vo);
	}

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 OrderItemVO
	 * @exception Exception
	 */
	@Override
	public void deleteOrderItem(OrderItemVO vo) throws Exception {
		orderItemMapper.deleteOrderItem(vo);
	}

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 OrderItemVO
	 * @return 조회한 글
	 * @exception Exception
	 */
	@Override
	public OrderItemVO selectOrderItem(OrderItemVO vo) throws Exception {
		OrderItemVO resultVO = orderItemMapper.selectOrderItem(vo);
		// if (resultVO == null)
		//  	throw processException("info.nodata.msg");
		return resultVO;
	}

	/**
	 * 글 목록을 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 목록
	 * @exception Exception
	 */
	@Override
	public List<?> selectOrderItemList(OrderItemVO vo) throws Exception {
		return orderItemMapper.selectOrderItemList(vo);
	}

	/**
	 * 글 총 갯수를 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 총 갯수
	 * @exception
	 */
	@Override
	public int selectOrderItemListTotCnt(OrderItemVO vo) {
		return orderItemMapper.selectOrderItemListTotCnt(vo);
	}

}
