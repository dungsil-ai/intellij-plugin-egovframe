public interface OrderItemService {

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 OrderItemVO
	 * @exception Exception
	 */
	void insertOrderItem(OrderItemVO vo) throws Exception;

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 OrderItemVO
	 * @exception Exception
	 */
	void updateOrderItem(OrderItemVO vo) throws Exception;

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 OrderItemVO
	 * @exception Exception
	 */
	void deleteOrderItem(OrderItemVO vo) throws Exception;

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 OrderItemVO
	 * @return 조회한 글
	 * @exception Exception
	 */
	OrderItemVO selectOrderItem(OrderItemVO vo) throws Exception;

	/**
	 * 글 목록을 조회한다.
	 * @param vo - 조회할 정보가 담긴 OrderItemVO
	 * @return 글 목록
	 * @exception Exception
	 */
	List<?> selectOrderItemList(OrderItemVO vo) throws Exception;

	/**
	 * 글 총 갯수를 조회한다.
	 * @param vo - 조회할 정보가 담긴 OrderItemVO
	 * @return 글 총 갯수
	 * @exception
	 */
	int selectOrderItemListTotCnt(OrderItemVO vo);

}
