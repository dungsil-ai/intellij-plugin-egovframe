public interface BoardArticleService {

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 BoardArticleVO
	 * @exception Exception
	 */
	void insertBoardArticle(BoardArticleVO vo) throws Exception;

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 BoardArticleVO
	 * @exception Exception
	 */
	void updateBoardArticle(BoardArticleVO vo) throws Exception;

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 BoardArticleVO
	 * @exception Exception
	 */
	void deleteBoardArticle(BoardArticleVO vo) throws Exception;

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 BoardArticleVO
