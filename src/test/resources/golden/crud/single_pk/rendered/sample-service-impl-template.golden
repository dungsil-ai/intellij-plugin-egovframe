package egovframework.example.sample.service.impl;

import java.util.List;

import org.egovframe.rte.fdl.cmmn.EgovAbstractServiceImpl;
import org.egovframe.rte.fdl.idgnr.EgovIdGnrService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;

import egovframework.example.sample.service.BoardArticleService;
import egovframework.example.sample.service.BoardArticleVO;
import jakarta.annotation.Resource;

/**
 * @Class Name : BoardArticleServiceImpl.java
 * @Description : BoardArticle Business Implement Class
 * @Modification Information
 * @
 * @ 수정일 수정자 수정내용
 * @ --------- --------- -------------------------------
 * @ 2026-07-16 author 최초생성
 *
 * @author author
 * @since 2026-07-16
 * @version 1.0.0
 * @see
 *
 * Copyright (C) All right reserved.
 */
@Service("boardArticleService")
public class BoardArticleServiceImpl extends EgovAbstractServiceImpl implements BoardArticleService {

	private static final Logger LOGGER = LoggerFactory.getLogger(BoardArticleServiceImpl.class);

	/** BoardArticleMapper */
	@Resource(name = "boardArticleMapper")
	private BoardArticleMapper boardArticleMapper;

	/** ID Generation */
	@Resource(name = "egovIdGnrService")
	private EgovIdGnrService egovIdGnrService;

	/**
	 * 글을 등록한다.
	 * @param vo - 등록할 정보가 담긴 BoardArticleVO
	 * @exception Exception
	 */
	@Override
	public void insertBoardArticle(BoardArticleVO vo) throws Exception {
		LOGGER.debug(vo.toString());

		/** ID Generation Service */
		String id = egovIdGnrService.getNextStringId();
		vo.setArticleId(id);
		LOGGER.debug(vo.toString());

		boardArticleMapper.insertBoardArticle(vo);
	}

	/**
	 * 글을 수정한다.
	 * @param vo - 수정할 정보가 담긴 BoardArticleVO
	 * @exception Exception
	 */
	@Override
	public void updateBoardArticle(BoardArticleVO vo) throws Exception {
		boardArticleMapper.updateBoardArticle(vo);
	}

	/**
	 * 글을 삭제한다.
	 * @param vo - 삭제할 정보가 담긴 BoardArticleVO
	 * @exception Exception
	 */
	@Override
	public void deleteBoardArticle(BoardArticleVO vo) throws Exception {
		boardArticleMapper.deleteBoardArticle(vo);
	}

	/**
	 * 글을 조회한다.
	 * @param vo - 조회할 정보가 담긴 BoardArticleVO
	 * @return 조회한 글
	 * @exception Exception
	 */
	@Override
	public BoardArticleVO selectBoardArticle(BoardArticleVO vo) throws Exception {
		BoardArticleVO resultVO = boardArticleMapper.selectBoardArticle(vo);
		// if (resultVO == null)
		//  	throw processException("info.nodata.msg");
		return resultVO;
	}

	/**
	 * 글 목록을 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 목록
	 * @exception Exception
	 */
	@Override
	public List<?> selectBoardArticleList(BoardArticleVO vo) throws Exception {
		return boardArticleMapper.selectBoardArticleList(vo);
	}

	/**
	 * 글 총 갯수를 조회한다.
	 * @param vo - 조회할 정보가 담긴 VO
	 * @return 글 총 갯수
	 * @exception
	 */
	@Override
	public int selectBoardArticleListTotCnt(BoardArticleVO vo) {
		return boardArticleMapper.selectBoardArticleListTotCnt(vo);
	}

}
